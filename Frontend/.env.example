# ===========================================
# Frontend environment variables (Vite)
# ===========================================
# Copy this file to .env.local and edit values:
#   copy .env.example .env.local
#
# Variable names MUST start with VITE_ to work in the browser.
# Do NOT commit .env.local (it is in .gitignore).
#
# --- Local development ---
# VITE_API_BASE_URL=http://localhost:5011
#
# --- Production (Render backend) ---
# Paste your Render URL (no trailing slash):
VITE_API_BASE_URL=https://your-backend-name.onrender.com
#
# On Vercel: Settings → Environment Variables → add the same key/value
# Then redeploy the frontend.

VITE_API_BASE_URL=http://localhost:5011
